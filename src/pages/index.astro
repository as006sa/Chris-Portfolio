---
import "../styles/global.css";

const strengths = [
  {
    title: "Business Workflow Systems",
    titleZh: "企業流程系統",
    detail: "Forms, approval states, permissions, attachments, reporting, and maintainable internal operations.",
    detailZh: "表單、簽核狀態、權限、附件、報表，以及可維護的內部營運流程。"
  },
  {
    title: "Full-stack Implementation",
    titleZh: "全端實作",
    detail: "Vue, React, FastAPI, Express, PostgreSQL, file storage, admin interfaces, and data-heavy UI.",
    detailZh: "Vue、React、FastAPI、Express、PostgreSQL、檔案儲存、後台介面與資料密集型 UI。"
  },
  {
    title: "Production Delivery",
    titleZh: "上線交付",
    detail: "GitHub version control, Render deployment, Cloudflare DNS/R2, build checks, smoke tests, and E2E coverage.",
    detailZh: "GitHub 版控、Render 部署、Cloudflare DNS/R2、build 檢查、smoke test 與 E2E 測試。"
  }
];

const projectEntrances = [
  {
    title: "Light Show",
    titleZh: "Light Show",
    type: "Live Product",
    typeZh: "公開上線作品",
    href: "/projects/light-show/",
    external: "https://lighting.hj-corp.cc/",
    summary: "Lighting storefront and admin platform with product management, inquiries, SEO, R2 storage, Neon PostgreSQL, and deployment.",
    summaryZh: "燈飾展示網站與後台管理平台，包含商品管理、詢價、SEO、R2 儲存、Neon PostgreSQL 與部署。"
  },
  {
    title: "Enterprise Intranet Systems",
    titleZh: "企業內網系統",
    type: "Internal Systems",
    typeZh: "公司內部系統",
    href: "/projects/intranet-systems/",
    external: "",
    summary: "Workflow modules for OKR, ECN, overtime, reimbursement, project codes, delegation, asset tracking, equipment maintenance, and BOM control.",
    summaryZh: "涵蓋 OKR、ECN、加班、核銷、專案代碼、職務代理、資產追蹤、設備維護與 BOM 版控的流程系統。"
  }
];

const experience = [
  {
    period: "2026 H1",
    periodZh: "2026 上半年",
    title: "Enterprise internal systems development",
    titleZh: "企業內部系統開發",
    detail: "Built and improved modules for approvals, OKR evaluation, assets, equipment maintenance, BOM control, pricing workflows, and operational reporting.",
    detailZh: "開發並優化簽核、OKR 評核、資產、設備維護、BOM 版控、價格流程與營運報表相關模組。"
  },
  {
    period: "2026 Jun-Jul",
    periodZh: "2026 六月至七月",
    title: "Light Show public launch",
    titleZh: "Light Show 公開上線",
    detail: "Delivered a public storefront and admin system, connected database and object storage services, added verification checks, and deployed the product.",
    detailZh: "完成公開前台與後台系統，串接資料庫與物件儲存，加入驗證檢查並部署上線。"
  },
  {
    period: "Now",
    periodZh: "目前",
    title: "Portfolio and case study packaging",
    titleZh: "作品集與案例整理",
    detail: "Turning project work into clear case studies that communicate business context, technical ownership, and production delivery.",
    detailZh: "將專案成果整理為清楚案例，呈現業務情境、技術負責範圍與上線交付能力。"
  }
];

const caseSummaries = [
  {
    title: "Light Show",
    titleZh: "Light Show",
    role: "End-to-end product implementation",
    roleZh: "端到端產品實作",
    bullets: [
      "Built storefront, admin console, API server, database schema, file upload flow, and deployment configuration.",
      "Implemented product CRUD, category management, CSV import, inquiry handling, catalog PDFs, dashboard metrics, and SEO settings.",
      "Added build checks, API smoke testing, and Playwright E2E coverage for important user and admin flows."
    ],
    bulletsZh: [
      "建立前台、後台、API server、資料庫 schema、檔案上傳流程與部署設定。",
      "實作商品 CRUD、分類管理、CSV 匯入、詢價處理、PDF 型錄、儀表板指標與 SEO 設定。",
      "加入 build 檢查、API smoke test 與 Playwright E2E，覆蓋重要前台與後台流程。"
    ],
    stack: ["React", "Vite", "Express", "Neon PostgreSQL", "Drizzle", "Cloudflare R2", "Render", "Playwright"]
  },
  {
    title: "Enterprise Intranet Systems",
    titleZh: "企業內網系統",
    role: "Feature development and workflow maintenance",
    roleZh: "功能開發與流程維護",
    bullets: [
      "Converted spreadsheet, paper, and manual follow-up processes into database-backed web workflows.",
      "Worked on approvals, role access, attachments, searchable lists, reporting views, and version history.",
      "Covered OKR, ECN, overtime, travel reimbursement, project codes, delegation, asset tracking, equipment maintenance, and BOM control."
    ],
    bulletsZh: [
      "將 Excel、紙本與人工追蹤流程轉成資料庫支援的 Web 流程。",
      "處理簽核、角色權限、附件、查詢列表、報表畫面與版本歷程。",
      "涵蓋 OKR、ECN、加班、出差核銷、專案代碼、職務代理、資產追蹤、設備維護與 BOM 版控。"
    ],
    stack: ["Vue 3", "FastAPI", "Python", "PostgreSQL", "Element Plus", "PrimeVue"]
  }
];

const skills = [
  ["Frontend", "Vue 3, React, Vite, Admin UI, Forms, Tables, Responsive layout"],
  ["Backend", "FastAPI, Express, REST API, Sessions, File uploads, Validation"],
  ["Data & Storage", "PostgreSQL, Neon, Drizzle, Cloudflare R2, CSV import, Report files"],
  ["Delivery", "Git, GitHub, Render, Cloudflare DNS, Playwright, Smoke tests"]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Chris Tsai is a full-stack developer focused on enterprise workflow systems, internal tools, and production web products."
    />
    <meta property="og:title" content="Chris Tsai | Full-stack Developer" />
    <meta property="og:description" content="Resume-style portfolio for workflow systems, internal tools, and full-stack delivery." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/chris-profile.jpg" />
    <title>Chris Tsai | Full-stack Developer</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Chris Tsai home">
        <span>CT</span>
        <strong>Chris Tsai</strong>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#projects">Projects</a>
        <a href="#experience">Experience</a>
        <a href="#cases">Cases</a>
        <a href="#skills">Skills</a>
        <a href="https://github.com/as006sa" target="_blank" rel="noreferrer">GitHub</a>
        <a href="#contact">Contact</a>
        <button class="lang-toggle" type="button" data-lang-toggle>中文</button>
      </nav>
    </header>

    <main id="top">
      <section class="resume-hero">
        <aside class="identity-card">
          <img src="/assets/chris-profile.jpg" alt="Portrait of Chris Tsai" />
          <div>
            <p class="identity-name">
              <span data-en>Chris Tsai</span>
              <span data-zh>蔡侑晟 Chris Tsai</span>
            </p>
            <p class="identity-role">
              <span data-en>Full-stack Developer / Internal System Builder</span>
              <span data-zh>全端工程師 / 企業內部系統開發</span>
            </p>
            <div class="identity-links">
              <a href="mailto:as006sa@gmail.com">as006sa@gmail.com</a>
              <a href="https://github.com/as006sa" target="_blank" rel="noreferrer">github.com/as006sa</a>
            </div>
          </div>
        </aside>

        <section class="resume-summary" aria-labelledby="intro-title">
          <p class="eyebrow">
            <span data-en>Portfolio Summary</span>
            <span data-zh>作品集摘要</span>
          </p>
          <h1 id="intro-title">
            <span data-en>Full-stack developer focused on business workflow systems.</span>
            <span data-zh>專注企業流程系統的全端工程師。</span>
          </h1>
          <p class="lead">
            <span data-en>I build practical systems for forms, approvals, operational data, file handling, admin workflows, and production deployment. My recent work combines enterprise intranet modules with a live public product.</span>
            <span data-zh>我開發表單、簽核、營運資料、檔案處理、後台管理與可部署上線的系統。近期成果包含公司內網流程模組，以及一個已公開上線的產品。</span>
          </p>

          <div class="strength-list" aria-label="Core strengths">
            {
              strengths.map((item) => (
                <article>
                  <h2><span data-en>{item.title}</span><span data-zh>{item.titleZh}</span></h2>
                  <p><span data-en>{item.detail}</span><span data-zh>{item.detailZh}</span></p>
                </article>
              ))
            }
          </div>
        </section>
      </section>

      <section class="section project-entry-section" id="projects">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Projects</p>
          <h2>
            <span data-en>Two proof points: one live product, one internal systems track.</span>
            <span data-zh>兩個主要證明：公開上線產品與企業內部系統實戰。</span>
          </h2>
        </div>
        <div class="entry-grid">
          {
            projectEntrances.map((project) => (
              <article class="entry-card">
                <p class="entry-type"><span data-en>{project.type}</span><span data-zh>{project.typeZh}</span></p>
                <h3><span data-en>{project.title}</span><span data-zh>{project.titleZh}</span></h3>
                <p><span data-en>{project.summary}</span><span data-zh>{project.summaryZh}</span></p>
                <div class="entry-actions">
                  <a href={project.href}><span data-en>Case study</span><span data-zh>案例說明</span></a>
                  {project.external && <a href={project.external} target="_blank" rel="noreferrer"><span data-en>Live site</span><span data-zh>線上網站</span></a>}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="experience">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Experience</p>
          <h2>
            <span data-en>Recent delivery record.</span>
            <span data-zh>近期交付紀錄。</span>
          </h2>
        </div>
        <div class="resume-table">
          {
            experience.map((item) => (
              <article>
                <span><span data-en>{item.period}</span><span data-zh>{item.periodZh}</span></span>
                <h3><span data-en>{item.title}</span><span data-zh>{item.titleZh}</span></h3>
                <p><span data-en>{item.detail}</span><span data-zh>{item.detailZh}</span></p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="cases">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Case Notes</p>
          <h2>
            <span data-en>What I actually owned in each project.</span>
            <span data-zh>我在專案中實際負責的內容。</span>
          </h2>
        </div>
        <div class="case-note-list">
          {
            caseSummaries.map((caseItem) => (
              <article class="case-note">
                <div>
                  <p class="entry-type"><span data-en>{caseItem.role}</span><span data-zh>{caseItem.roleZh}</span></p>
                  <h3><span data-en>{caseItem.title}</span><span data-zh>{caseItem.titleZh}</span></h3>
                </div>
                <div>
                  <ul>
                    {caseItem.bullets.map((bullet, index) => (
                      <li><span data-en>{bullet}</span><span data-zh>{caseItem.bulletsZh[index]}</span></li>
                    ))}
                  </ul>
                  <div class="tags">
                    {caseItem.stack.map((item) => <span>{item}</span>)}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="skills">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Skills</p>
          <h2>
            <span data-en>Technical stack used in real delivery.</span>
            <span data-zh>實際交付中使用的技術組合。</span>
          </h2>
        </div>
        <div class="skill-matrix">
          {
            skills.map(([group, items]) => (
              <article>
                <h3>{group}</h3>
                <p>{items}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="contact compact-contact" id="contact">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>
            <span data-en>Open to full-stack roles focused on internal tools and workflow systems.</span>
            <span data-zh>正在尋找聚焦內部工具與流程系統的全端工程角色。</span>
          </h2>
        </div>
        <div class="contact-actions">
          <a class="button primary" href="https://lighting.hj-corp.cc/" target="_blank" rel="noreferrer">Light Show</a>
          <a class="button secondary" href="https://github.com/as006sa" target="_blank" rel="noreferrer">GitHub</a>
          <a class="button secondary" href="mailto:as006sa@gmail.com">as006sa@gmail.com</a>
        </div>
      </section>
    </main>

    <script>
      const button = document.querySelector("[data-lang-toggle]");
      const savedLang = localStorage.getItem("portfolio-lang");
      const initialLang = savedLang === "zh" || savedLang === "en" ? savedLang : navigator.language?.startsWith("zh") ? "zh" : "en";

      function setLang(lang: "en" | "zh") {
        document.documentElement.dataset.lang = lang;
        document.documentElement.lang = lang === "zh" ? "zh-Hant" : "en";
        localStorage.setItem("portfolio-lang", lang);
        if (button) button.textContent = lang === "zh" ? "EN" : "中文";
      }

      setLang(initialLang);
      button?.addEventListener("click", () => {
        setLang(document.documentElement.dataset.lang === "zh" ? "en" : "zh");
      });
    </script>
  </body>
</html>
