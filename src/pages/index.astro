---
import "../styles/global.css";

const projects = [
  {
    title: "Light Show",
    label: "Live public product",
    labelZh: "公開線上作品",
    href: "/projects/light-show/",
    external: "https://lighting.hj-corp.cc/",
    summary:
      "A production lighting storefront with product management, inquiry handling, SEO controls, R2 file storage, and an admin console.",
    summaryZh:
      "已上線的燈飾展示網站，包含商品管理、詢價流程、SEO 設定、R2 檔案儲存與後台管理介面。",
    stack: ["React", "Vite", "Express", "Neon PostgreSQL", "Drizzle", "Cloudflare R2", "Render"],
    points: [
      "Designed the storefront and admin workflows around real product and inquiry operations.",
      "Connected API, PostgreSQL schema, image storage, catalog files, and production deployment.",
      "Added build checks, API smoke tests, and Playwright E2E coverage for critical flows."
    ],
    pointsZh: [
      "依照實際商品展示與詢價營運流程設計前台與後台功能。",
      "串接 API、PostgreSQL schema、圖片儲存、型錄檔案與正式部署。",
      "加入 build 檢查、API smoke test 與 Playwright E2E 測試，覆蓋關鍵流程。"
    ]
  },
  {
    title: "Enterprise Intranet Platform",
    titleZh: "企業內網系統平台",
    label: "Internal business systems",
    labelZh: "公司內部系統",
    href: "/projects/intranet-systems/",
    external: "",
    summary:
      "A suite of internal systems for approval workflows, OKR evaluation, asset tracking, BOM control, and operational reporting.",
    summaryZh:
      "公司內部系統群，涵蓋簽核流程、OKR 評核、資產追蹤、BOM 版控與營運報表。",
    stack: ["Vue 3", "FastAPI", "Python", "PostgreSQL", "Element Plus", "PrimeVue"],
    points: [
      "Moved spreadsheet and paper-based operations into traceable web workflows.",
      "Implemented forms, permissions, approval stages, file attachments, lists, and reporting views.",
      "Maintained multiple business modules while adapting to real workflow changes."
    ],
    pointsZh: [
      "將原本仰賴 Excel、紙本與人工追蹤的流程轉成可查詢的 Web 系統。",
      "實作表單、權限、簽核關卡、附件、查詢列表與報表畫面。",
      "維護多個業務模組，並依照實際使用後的流程變動持續調整。"
    ]
  }
];

const workHighlights = [
  "OKR evaluation workflow",
  "ECN engineering change process",
  "Overtime request and outcome tracking",
  "Business trip request and reimbursement",
  "Project code management",
  "Delegation and permission management",
  "Asset QR code history tracking",
  "Asset inventory workflow",
  "Equipment registration and maintenance",
  "BOM version control",
  "Market price and sales cost tools"
];

const skills = [
  {
    title: "Frontend",
    items: ["Vue 3", "React", "Vite", "Admin UI", "Forms", "Tables", "Responsive layout"]
  },
  {
    title: "Backend",
    items: ["FastAPI", "Express", "REST API", "Session flows", "File uploads", "Validation"]
  },
  {
    title: "Data & Storage",
    items: ["PostgreSQL", "Neon", "Drizzle", "Cloudflare R2", "CSV import", "Report files"]
  },
  {
    title: "Delivery",
    items: ["Git", "GitHub", "Render", "Cloudflare DNS", "Playwright", "Smoke tests"]
  }
];

const timeline = [
  {
    period: "2026 H1",
    periodZh: "2026 上半年",
    title: "Internal systems delivery",
    titleZh: "企業內部系統交付",
    detail:
      "Built and improved workflow modules covering approvals, OKR evaluation, asset management, equipment maintenance, BOM control, and pricing operations."
    ,
    detailZh:
      "開發並優化簽核、OKR 評核、資產管理、設備維護、BOM 版控與價格相關營運模組。"
  },
  {
    period: "2026 Jun-Jul",
    periodZh: "2026 六月至七月",
    title: "Light Show launch",
    titleZh: "Light Show 上線",
    detail:
      "Built a public storefront and admin platform, connected storage and database services, added test coverage, and deployed the site to production."
    ,
    detailZh:
      "完成公開前台與後台管理平台，串接資料庫與雲端儲存，加入測試覆蓋並部署上線。"
  },
  {
    period: "Now",
    periodZh: "目前",
    title: "Portfolio packaging",
    titleZh: "作品集整理",
    detail:
      "Turning project work into clear case studies that communicate product thinking, implementation scope, and production ownership."
    ,
    detailZh:
      "將專案成果整理成清楚的案例，呈現產品思考、實作範圍與上線維護能力。"
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Chris Tsai is a full-stack developer focused on enterprise workflow systems, internal tools, and production web products."
    />
    <meta property="og:title" content="Chris Tsai | Full-stack Developer" />
    <meta
      property="og:description"
      content="Portfolio focused on workflow automation, internal systems, and production web delivery."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/workflow-snapshot.png" />
    <title>Chris Tsai | Full-stack Developer</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Chris Tsai home">
        <span>CT</span>
        <strong>Chris Tsai</strong>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#projects">Projects</a>
        <a href="#cases">Cases</a>
        <a href="#experience">Experience</a>
        <a href="#skills">Skills</a>
        <a href="https://github.com/as006sa" target="_blank" rel="noreferrer">GitHub</a>
        <a href="#contact">Contact</a>
        <button class="lang-toggle" type="button" data-lang-toggle>中文</button>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">
            <span data-en>Full-stack Developer / Internal System Builder</span>
            <span data-zh>全端工程師 / 企業內部系統開發</span>
          </p>
          <h1>
            <span data-en>I turn business workflows into reliable web systems.</span>
            <span data-zh>把公司流程、資料與簽核需求，做成可靠的 Web 系統。</span>
          </h1>
          <p class="lead">
            <span data-en>
              I build practical software for forms, approvals, operational data, file handling, and admin workflows. Recent work includes a production lighting storefront and multiple enterprise intranet systems.
            </span>
            <span data-zh>
              我專注在表單、簽核、營運資料、檔案處理與後台管理流程。近期完成已上線的燈飾展示網站，以及多個企業內網系統模組。
            </span>
          </p>
          <div class="profile-card">
            <img src="/assets/chris-profile.jpg" alt="Portrait of Chris Tsai" />
            <div>
              <strong>Chris Tsai</strong>
              <span data-en>Full-stack developer based in Taiwan</span>
              <span data-zh>台灣全端工程師，聚焦企業流程系統</span>
            </div>
          </div>
          <div class="hero-actions">
            <a class="button primary" href="#projects">
              <span data-en>View projects</span>
              <span data-zh>查看作品</span>
            </a>
            <a class="button secondary" href="https://lighting.hj-corp.cc/" target="_blank" rel="noreferrer">
              <span data-en>Open live product</span>
              <span data-zh>開啟線上作品</span>
            </a>
          </div>
        </div>

        <div class="system-preview" aria-label="Portfolio system preview">
          <div class="preview-toolbar">
            <span></span>
            <span></span>
            <span></span>
            <strong>workflow-console</strong>
          </div>
          <img
            class="preview-image"
            src="/assets/workflow-snapshot.png"
            alt="Dashboard style overview of Chris Tsai's portfolio systems"
            loading="eager"
          />
          <div class="preview-grid">
            <div class="metric-block">
              <span>Public product</span>
              <strong>Light Show</strong>
              <small>Storefront + Admin + R2</small>
            </div>
            <div class="metric-block">
              <span>Internal delivery</span>
              <strong>11+</strong>
              <small>Workflow modules shipped</small>
            </div>
            <div class="flow-map">
              <div>Request</div>
              <i></i>
              <div>Review</div>
              <i></i>
              <div>Approve</div>
              <i></i>
              <div>Report</div>
            </div>
            <div class="signal-list">
              <p><span></span> API connected</p>
              <p><span></span> Files tracked</p>
              <p><span></span> Build verified</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section compact">
        <div class="strip">
          <div>
            <strong><span data-en>Business workflows</span><span data-zh>企業流程</span></strong>
            <span data-en>approval, forms, permissions</span>
            <span data-zh>簽核、表單、權限</span>
          </div>
          <div>
            <strong><span data-en>Full-stack delivery</span><span data-zh>全端交付</span></strong>
            <span data-en>frontend, API, database, storage</span>
            <span data-zh>前端、API、資料庫、檔案儲存</span>
          </div>
          <div>
            <strong><span data-en>Production mindset</span><span data-zh>上線思維</span></strong>
            <span data-en>deployment, tests, maintainability</span>
            <span data-zh>部署、測試、可維護性</span>
          </div>
        </div>
      </section>

      <section class="section" id="projects">
        <div class="section-heading">
          <p class="eyebrow">Selected Projects</p>
          <h2>
            <span data-en>Two project tracks that show both product delivery and enterprise systems work.</span>
            <span data-zh>兩條專案主軸：公開產品交付與企業內部系統實戰。</span>
          </h2>
          <p>
            <span data-en>The public project is directly accessible. Internal company work is described at the architecture and workflow level to avoid exposing private data.</span>
            <span data-zh>公開作品可以直接瀏覽；公司內部專案則以架構與流程層級呈現，避免揭露敏感資料。</span>
          </p>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class="card-topline">
                  <span><span data-en>{project.label}</span><span data-zh>{project.labelZh}</span></span>
                  <a href={project.href}><span data-en>Case study</span><span data-zh>案例頁</span></a>
                </div>
                <h3><span data-en>{project.title}</span><span data-zh>{project.titleZh || project.title}</span></h3>
                <p><span data-en>{project.summary}</span><span data-zh>{project.summaryZh}</span></p>
                <ul class="point-list">
                  {project.points.map((point, index) => (
                    <li><span data-en>{point}</span><span data-zh>{project.pointsZh[index]}</span></li>
                  ))}
                </ul>
                <div class="tags">
                  {project.stack.map((item) => (
                    <span>{item}</span>
                  ))}
                </div>
                {project.external && (
                  <a class="text-link" href={project.external} target="_blank" rel="noreferrer">
                    <span data-en>Visit live site</span>
                    <span data-zh>查看線上網站</span>
                  </a>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section class="section cases" id="cases">
        <div class="section-heading">
          <p class="eyebrow">Case Studies</p>
          <h2><span data-en>How I frame and deliver systems.</span><span data-zh>我如何整理需求並交付系統。</span></h2>
        </div>

        <article class="case-row" id="case-light-show">
          <div>
            <p class="eyebrow">From idea to production</p>
            <h3><span data-en>Light Show: storefront, admin console, storage, and deployment</span><span data-zh>Light Show：前台、後台、儲存與部署</span></h3>
          </div>
          <div class="case-content">
            <p>
              <span data-en>Light Show is a production website for browsing lighting products and managing product operations. It gave me a complete path from product requirements to public deployment.</span>
              <span data-zh>Light Show 是一個已上線的燈飾商品展示與後台管理網站，讓我完整走過從需求、實作到公開部署的流程。</span>
            </p>
            <dl>
              <div>
                <dt><span data-en>Role</span><span data-zh>角色</span></dt>
                <dd><span data-en>Owned frontend, API, database schema, file storage, deployment configuration, and verification workflow.</span><span data-zh>負責前端、API、資料庫 schema、檔案儲存、部署設定與驗證流程。</span></dd>
              </div>
              <div>
                <dt><span data-en>Implementation</span><span data-zh>實作</span></dt>
                <dd><span data-en>React/Vite for the user and admin interfaces, Express for API routes, Neon PostgreSQL for data, Cloudflare R2 for files, and Render for hosting.</span><span data-zh>使用 React/Vite 建立前台與後台，Express 提供 API，Neon PostgreSQL 儲存資料，Cloudflare R2 管理檔案，Render 負責部署。</span></dd>
              </div>
              <div>
                <dt><span data-en>Quality</span><span data-zh>品質控管</span></dt>
                <dd><span data-en>Added type checks, smoke tests, and Playwright coverage for homepage, admin login, product CRUD, search, product detail, settings, and inquiries.</span><span data-zh>加入型別檢查、smoke test 與 Playwright E2E，覆蓋首頁、後台登入、商品 CRUD、搜尋、商品詳情、設定與詢價流程。</span></dd>
              </div>
            </dl>
          </div>
        </article>

        <article class="case-row" id="case-intranet">
          <div>
            <p class="eyebrow">Internal workflow systems</p>
            <h3><span data-en>Enterprise intranet: approvals, assets, OKR, BOM, and operational tools</span><span data-zh>企業內網：簽核、資產、OKR、BOM 與營運工具</span></h3>
          </div>
          <div class="case-content">
            <p>
              <span data-en>Internal company systems are private, so the portfolio describes them without screenshots, credentials, or sensitive process data. The important signal is the type of complexity handled: permissions, states, attachments, review stages, reporting, and changing business rules.</span>
              <span data-zh>公司內部系統屬於私有專案，因此作品集不放截圖、帳號或敏感流程資料；重點放在處理過的複雜度：權限、狀態、附件、審核關卡、報表與持續變動的業務規則。</span>
            </p>
            <dl>
              <div>
                <dt>System types</dt>
                <dd>OKR evaluation, ECN, overtime forms, business trip reimbursement, project code management, delegation, asset tracking, equipment maintenance, and BOM version control.</dd>
              </div>
              <div>
                <dt>Engineering focus</dt>
                <dd>Data forms, approval status transitions, role-based access, file attachments, searchable lists, report exports, and integrations with existing business data.</dd>
              </div>
              <div>
                <dt>Value</dt>
                <dd>Made operational processes easier to trace, review, search, and maintain compared with manual follow-ups and scattered spreadsheet files.</dd>
              </div>
            </dl>
          </div>
        </article>
      </section>

      <section class="section timeline-section" id="experience">
        <div class="section-heading">
          <p class="eyebrow">Experience</p>
          <h2><span data-en>Recent delivery timeline.</span><span data-zh>近期交付時間線。</span></h2>
        </div>
        <div class="timeline">
          {
            timeline.map((item) => (
              <article>
                <span><span data-en>{item.period}</span><span data-zh>{item.periodZh}</span></span>
                <h3><span data-en>{item.title}</span><span data-zh>{item.titleZh}</span></h3>
                <p><span data-en>{item.detail}</span><span data-zh>{item.detailZh}</span></p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section worklog">
        <div class="section-heading">
          <p class="eyebrow">Recent Work</p>
          <h2><span data-en>Business domains covered in the past half year.</span><span data-zh>近半年參與的業務系統主題。</span></h2>
        </div>
        <div class="work-grid">
          {
            workHighlights.map((item) => (
              <span>{item}</span>
            ))
          }
        </div>
      </section>

      <section class="section" id="skills">
        <div class="section-heading">
          <p class="eyebrow">Skills</p>
          <h2><span data-en>A stack for building and shipping business tools.</span><span data-zh>能把企業工具做出來並部署上線的技術組合。</span></h2>
        </div>
        <div class="skill-grid">
          {
            skills.map((group) => (
              <section class="skill-card">
                <h3>{group.title}</h3>
                <div class="tags">
                  {group.items.map((item) => (
                    <span>{item}</span>
                  ))}
                </div>
              </section>
            ))
          }
        </div>
      </section>

      <section class="contact" id="contact">
        <div>
          <p class="eyebrow">Contact</p>
          <h2><span data-en>Open to roles where business workflows need strong implementation.</span><span data-zh>正在尋找能把業務流程落地成系統的工程角色。</span></h2>
          <p>
            <span data-en>LinkedIn and a resume PDF can be added here once the final public profile information is confirmed.</span>
            <span data-zh>LinkedIn 與履歷 PDF 之後確認後可以再補上。</span>
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href="https://lighting.hj-corp.cc/" target="_blank" rel="noreferrer">Light Show</a>
          <a class="button secondary" href="https://github.com/as006sa" target="_blank" rel="noreferrer">GitHub</a>
          <a class="button secondary" href="mailto:as006sa@gmail.com">as006sa@gmail.com</a>
        </div>
      </section>
    </main>
    <script>
      const button = document.querySelector("[data-lang-toggle]");
      const savedLang = localStorage.getItem("portfolio-lang");
      const initialLang = savedLang === "zh" || savedLang === "en" ? savedLang : navigator.language?.startsWith("zh") ? "zh" : "en";

      function setLang(lang: "en" | "zh") {
        document.documentElement.dataset.lang = lang;
        document.documentElement.lang = lang === "zh" ? "zh-Hant" : "en";
        localStorage.setItem("portfolio-lang", lang);
        if (button) button.textContent = lang === "zh" ? "EN" : "中文";
      }

      setLang(initialLang);
      button?.addEventListener("click", () => {
        setLang(document.documentElement.dataset.lang === "zh" ? "en" : "zh");
      });
    </script>
  </body>
</html>
